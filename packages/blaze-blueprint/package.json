{
  "name": "@blaze-cardano/blueprint",
  "description": "CIP-57 implementation and generator",
  "version": "0.8.2",
  "bin": "./dist/cli.cjs",
  "devDependencies": {
    "@blaze-cardano/core": "workspace:*",
    "@blaze-cardano/data": "workspace:*",
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/jest-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "@blaze-cardano/tx": "workspace:*",
    "@blaze-cardano/uplc": "workspace:*",
    "@commander-js/extra-typings": "^12.1.0",
    "@sinclair/typebox": "^0.34.28",
    "@types/jest": "^30.0.0",
    "commander": "^12.1.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "tsdown": "^0.21.0",
    "tsx": "^4.16.2",
    "typescript": "^5.7.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "inlinedDependencies": {
    "commander": "12.1.0",
    "@commander-js/extra-typings": "12.1.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "build": "tsdown",
    "build:types": "tsc -p tsconfig.docs.json",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "cli": "node dist/cli.cjs",
    "dev": "tsdown --watch",
    "dev:cli": "tsdown --watch",
    "lint": "eslint .",
    "test": "bun run test:simple && bun run test:complex && bun run test:generic",
    "test:complex": "cd tests/complex && tsx blueprint_generate.ts && jest complex.test.ts",
    "test:generic": "cd tests/generic && tsx blueprint_generate.ts && jest generic.test.ts",
    "test:simple": "cd tests/simple && tsx blueprint_generate.ts && jest simple.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "types": "./dist/index.d.cts"
}
