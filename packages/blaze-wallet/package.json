{
  "name": "@blaze-cardano/wallet",
  "description": "Blaze cardano wallet library",
  "version": "0.5.3",
  "dependencies": {
    "@blaze-cardano/core": "workspace:*",
    "@blaze-cardano/query": "workspace:*",
    "@blaze-cardano/tx": "workspace:*",
    "@emurgo/cardano-message-signing-browser": "^1.1.0",
    "@emurgo/cardano-message-signing-nodejs": "^1.1.0"
  },
  "devDependencies": {
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "eslint": "^9.22.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "build": "tsdown",
    "build:types": "tsc -p tsconfig.docs.json",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.cts"
}
