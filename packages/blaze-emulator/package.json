{
  "name": "@blaze-cardano/emulator",
  "description": "Blaze cardano emulator library",
  "version": "0.5.2",
  "bin": {
    "blaze-emulator-rpc": "./dist/rpc/cli.mjs"
  },
  "dependencies": {
    "@blaze-cardano/core": "^0.9.1",
    "@blaze-cardano/query": "^0.6.2",
    "@blaze-cardano/sdk": "^0.3.1",
    "@blaze-cardano/tx": "^0.15.1",
    "@blaze-cardano/vm": "^0.3.1",
    "@blaze-cardano/wallet": "^0.6.1",
    "@hono/node-server": "^1.4.0",
    "@hono/swagger-ui": "^0.4.1",
    "@hono/zod-openapi": "^0.15.3",
    "@hono/zod-validator": "^0.2.1",
    "hono": "^4.12.31",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@blaze-cardano/blueprint": "workspace:*",
    "@blaze-cardano/data": "workspace:*",
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "@blaze-cardano/uplc": "workspace:*",
    "eslint": "^9.22.0",
    "tinybench": "^5.1.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./rpc": {
      "import": "./dist/rpc/index.mjs",
      "require": "./dist/rpc/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/butaneprotocol/blaze-cardano.git"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "bench": "bun benchmarks/index.ts",
    "build": "tsdown",
    "build:types": "tsc -p tsconfig.docs.json",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "coverage": "vitest run --coverage",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "serve:rpc": "bun src/rpc/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.cts"
}
