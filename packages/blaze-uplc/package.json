{
  "name": "@blaze-cardano/uplc",
  "description": "Blaze untyped plutus core library",
  "version": "0.4.3",
  "dependencies": {
    "@blaze-cardano/core": "workspace:*",
    "@blaze-cardano/data": "workspace:*",
    "hex-encoding": "^2.0.2"
  },
  "devDependencies": {
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/jest-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "@sinclair/typebox": "^0.34.28",
    "@types/jest": "^30.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3",
    "wasm-pack": "^0.13.1"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./wasm": {
      "types": "./dist/wasm/pkg-node/uplc_wasm.d.ts",
      "browser": "./dist/wasm/pkg-bundler/uplc_wasm.js",
      "import": "./dist/wasm/pkg-node/uplc_wasm.js",
      "default": "./dist/wasm/pkg-node/uplc_wasm.js"
    },
    "./wasm/web": {
      "types": "./dist/wasm/pkg-web/uplc_wasm.d.ts",
      "import": "./dist/wasm/pkg-web/uplc_wasm.js",
      "default": "./dist/wasm/pkg-web/uplc_wasm.js"
    },
    "./wasm/bundler": {
      "types": "./dist/wasm/pkg-bundler/uplc_wasm.d.ts",
      "import": "./dist/wasm/pkg-bundler/uplc_wasm.js",
      "default": "./dist/wasm/pkg-bundler/uplc_wasm.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "build": "tsdown && cd wasm && ./build.sh",
    "build:types": "tsc -p tsconfig.docs.json",
    "build:wasm": "cd wasm && ./build.sh",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "types": "./dist/index.d.cts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs"
}
