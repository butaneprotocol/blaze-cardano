{
  "name": "@blaze-cardano/sdk",
  "description": "Blaze cardano sdk library",
  "version": "0.3.1",
  "dependencies": {
    "@blaze-cardano/core": "^0.9.0",
    "@blaze-cardano/query": "^0.6.1",
    "@blaze-cardano/tx": "^0.15.1",
    "@blaze-cardano/uplc": "^0.5.1",
    "@blaze-cardano/wallet": "^0.6.1"
  },
  "devDependencies": {
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "eslint": "^9.22.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./blaze": {
      "import": "./dist/blaze.mjs",
      "require": "./dist/blaze.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/butaneprotocol/blaze-cardano.git"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "build": "tsdown",
    "build:types": "tsc -p tsconfig.docs.json",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.cts"
}
