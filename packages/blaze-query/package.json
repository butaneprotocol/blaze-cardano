{
  "name": "@blaze-cardano/query",
  "description": "Blaze Cardano chain-query provider library",
  "version": "0.6.1",
  "dependencies": {
    "@blaze-cardano/core": "^0.9.0",
    "@blaze-cardano/ogmios": "^0.0.7",
    "@cardano-ogmios/schema": "^6.6.1",
    "@cardanosolutions/json-bigint": "^1.0.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "@types/json-bigint": "^1.0.4",
    "@types/ws": "^8.5.10",
    "eslint": "^9.22.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/butaneprotocol/blaze-cardano.git"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "bench": "bun benchmarks/query-cache.ts",
    "build": "tsdown",
    "build:types": "npx tsc -p tsconfig.docs.json",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "watch": "tsdown --watch"
  },
  "type": "module",
  "types": "./dist/index.d.cts"
}
