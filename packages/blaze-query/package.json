{
  "name": "@blaze-cardano/query",
  "description": "Blaze cardano emulator library",
  "version": "0.5.6",
  "dependencies": {
    "@blaze-cardano/core": "workspace:*",
    "@blaze-cardano/jest-config": "workspace:*",
    "@blaze-cardano/ogmios": "workspace:*",
    "@cardano-ogmios/schema": "^6.6.1",
    "@cardanosolutions/json-bigint": "^1.0.2",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/json-bigint": "^1.0.4",
    "@types/ws": "^8.5.10",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "build": "tsdown",
    "build:types": "npx tsc -p tsconfig.docs.json",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "watch": "tsdown --watch"
  },
  "types": "./dist/index.d.cts"
}
