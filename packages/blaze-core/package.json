{
  "name": "@blaze-cardano/core",
  "description": "Blaze cardano core library",
  "version": "0.8.0",
  "dependencies": {
    "@foxglove/crc": "^0.0.3",
    "@noble/curves": "^1.8.1",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.1",
    "@scure/base": "^1.1.1",
    "@scure/bip39": "^1.5.4",
    "bech32": "^2.0.0",
    "blakejs": "^1.2.1",
    "fraction.js": "4.0.1",
    "ip-address": "^9.0.5",
    "libsodium-wrappers-sumo": "0.7.10",
    "lodash": "^4.17.21",
    "pbkdf2": "^3.1.3",
    "ts-custom-error": "^3.2.0",
    "web-encoding": "^1.1.5"
  },
  "devDependencies": {
    "@cardano-sdk/core": "^0.46",
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "eslint": "^9.22.0",
    "terser": "^5.37.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "api:extract": "api-extractor run --local --verbose",
    "api:md": "rimraf docs/api && api-documenter markdown -i etc -o docs/api",
    "api:prepare": "bun run build:types && bun run api:extract && bun run api:md",
    "build": "tsdown",
    "build:types": "tsc -p tsconfig.docs.json",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "vitest run",
    "vendor:sync": "node scripts/vendor-cardano-js-sdk.mjs",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.cts",
  "inlinedDependencies": {
    "@cardano-sdk/util": "0.17.1",
    "type-fest": "0.20.2",
    "ts-log": "2.2.7",
    "@cardano-sdk/core": "0.46.12",
    "@cardano-sdk/crypto": "0.4.5"
  }
}
