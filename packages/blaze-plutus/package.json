{
  "name": "@blaze-cardano/plutus",
  "description": "Pure TypeScript UPLC implementation (parser, name→DeBruijn, CEK machine, budgeting)",
  "version": "0.0.1",
  "dependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "@blaze-cardano/eslint-config": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "eslint": "^9.22.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bench": "vitest bench --run",
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "tsdown --watch",
    "download:conformance": "bash scripts/download-conformance.sh",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.cts"
}
