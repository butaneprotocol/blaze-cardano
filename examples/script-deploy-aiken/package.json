{
  "name": "script-deploy-aiken",
  "description": "Generate, deploy, and use a typed Aiken validator with Blaze",
  "version": "0.1.2",
  "dependencies": {
    "@blaze-cardano/data": "workspace:*",
    "@blaze-cardano/deploy": "workspace:*",
    "@blaze-cardano/emulator": "workspace:*",
    "@blaze-cardano/sdk": "workspace:*"
  },
  "devDependencies": {
    "@blaze-cardano/blueprint": "workspace:*",
    "@blaze-cardano/tsconfig": "workspace:*",
    "typescript": "^5.7.3"
  },
  "private": true,
  "scripts": {
    "build:aiken": "aiken build",
    "generate": "bunx @blaze-cardano/blueprint plutus.json --outfile plutus.ts --use-sdk",
    "start": "bun run build:aiken && bun run generate && bun run index.ts",
    "test": "bun run index.ts",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
