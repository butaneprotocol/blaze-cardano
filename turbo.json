{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["build"]
    },
    "@blaze-cardano/uplc#build": {
      "dependsOn": ["build:wasm"]
    },
    "@blaze-cardano/uplc#build:wasm": {},
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "api:prepare": {
      "dependsOn": ["^build"],
      "outputs": ["docs/api/**", "etc/**"]
    }
  }
}
